#!/bin/bash

start=$(date +%s)

echo "🔄 Updating Homebrew..."
brew update || true

echo "⬆️  Upgrading formulae and casks..."
brew upgrade --greedy || true

echo "🗑️  Removing orphaned dependencies..."
brew autoremove || true

echo "🧹 Cleaning up..."
brew cleanup -s --prune=all || true

echo "📦 Outdated (pinned or auto-updating packages may appear):"
brew outdated || true

echo "🧪 Running health checks..."
brew doctor || true

echo "✅ All done! ($(( $(date +%s) - start ))s)"
